{
  "routes": [
    {
      "routePath": "/api/booking/result/:ref",
      "mountPath": "/api/booking/result",
      "method": "GET",
      "module": [
        "api/booking/result/[ref].js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/booking/availability",
      "mountPath": "/api/booking",
      "method": "POST",
      "module": [
        "api/booking/availability.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/booking/calendar",
      "mountPath": "/api/booking",
      "method": "GET",
      "module": [
        "api/booking/calendar.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/booking/checkout",
      "mountPath": "/api/booking",
      "method": "POST",
      "module": [
        "api/booking/checkout.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/booking/quote",
      "mountPath": "/api/booking",
      "method": "POST",
      "module": [
        "api/booking/quote.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/contact",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/contact.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/experience-inquiry",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/experience-inquiry.js:onRequestPost"
      ]
    },
    {
      "routePath": "/api/fx",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/fx.js:onRequestGet"
      ]
    },
    {
      "routePath": "/api/track-session",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/track-session.js:onRequestPost"
      ]
    },
    {
      "routePath": "/:key.txt",
      "mountPath": "/",
      "method": "",
      "module": [
        "[key].txt.js:onRequest"
      ]
    },
    {
      "routePath": "/",
      "mountPath": "/",
      "method": "",
      "middleware": [
        "_middleware.js:onRequest"
      ]
    }
  ],
  "baseURL": "/"
}