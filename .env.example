# DEVOCEAN Lodge Email Automation System
# Add these secrets to Replit Secrets instead of using .env file

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# SMTP (Your Email Server - for sending emails)
MAIL_HOST=smtp.your-email-provider.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=booking@devoceanlodge.com
MAIL_PASSWORD=your_email_password
FROM_EMAIL=booking@devoceanlodge.com

# IMAP (Your Email Server - for reading Beds24 notifications)
IMAP_HOST=imap.your-email-provider.com
IMAP_PORT=993
IMAP_USER=booking@devoceanlodge.com
IMAP_PASSWORD=your_email_password
IMAP_TLS=true

# Taxi Company for Transfer Notifications (Optional)
TAXI_EMAIL=taxi@example.com
TAXI_WHATSAPP=+258123456789
TAXI_NAME=Ponta Transfer Service

# Admin Reporting (Optional - defaults to admin@devoceanlodge.com)
ADMIN_EMAIL=admin@devoceanlodge.com

# Admin API key (shared secret between the website's Cloudflare Pages Functions
# and this automailer; protects /api/track-session and /api/booking/* routes)
ADMIN_API_KEY=generate_a_long_random_string

# ─── Native Direct Booking (Beds24 REST API + Stripe deposit checkout) ───────
# Beds24 v2 API: long-life refresh token + single property id (DEVOCEAN = 297012)
BEDS24_REFRESH_TOKEN=your_beds24_long_life_refresh_token
BEDS24_PROP_ID=297012
BEDS24_API_BASE=https://beds24.com/api/v2

# Stripe: secret key + webhook signing secret (checkout.session.completed)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Booking policy (safe defaults shown; override to change deposit / cancellation)
DEPOSIT_PERCENT=30
CANCELLATION_POLICY_DAYS=30
BOOKING_CURRENCY=USD

# Public site URL — used to build Stripe success/cancel redirect URLs
PUBLIC_SITE_URL=https://devoceanlodge.com
